  "tokenColors": [
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#283850", "fontStyle": "italic" }
    },
    {
      "name": "String",
      "scope": ["string", "string.quoted", "string.template"],
      "settings": { "foreground": "#7888A0" }
    },
    {
      "name": "String escape",
      "scope": ["constant.character.escape", "string.regexp"],
      "settings": { "foreground": "#8898B0" }
    },
    {
      "name": "Number",
      "scope": ["constant.numeric"],
      "settings": { "foreground": "#5ABABA" }
    },
    {
      "name": "Boolean / Null",
      "scope": [
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined"
      ],
      "settings": { "foreground": "#5ABABA" }
    },
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": { "foreground": "#6070A0" }
    },
    {
      "name": "Function / Method",
      "scope": [
        "entity.name.function",
        "meta.function-call",
        "support.function",
        "variable.function"
      ],
      "settings": { "foreground": "#4A8888" }
    },
    {
      "name": "Class / Type",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.class",
        "support.type"
      ],
      "settings": { "foreground": "#5888A8" }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite"
      ],
      "settings": { "foreground": "#C8D0DC" }
    },
    {
      "name": "Variable — parameter",
      "scope": ["variable.parameter"],
      "settings": { "foreground": "#A8B4C4" }
    },
    {
      "name": "Constant",
      "scope": ["variable.other.constant", "constant.other"],
      "settings": { "foreground": "#7888A0", "fontStyle": "bold" }
    },
    {
      "name": "Property",
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key"
      ],
      "settings": { "foreground": "#B0BCC8" }
    },
    {
      "name": "Operator",
      "scope": ["keyword.operator", "punctuation.separator", "punctuation.accessor"],
      "settings": { "foreground": "#4A5870" }
    },
    {
      "name": "Punctuation",
      "scope": ["punctuation", "meta.brace", "meta.delimiter"],
      "settings": { "foreground": "#344055" }
    },
    {
      "name": "Decorator / Annotation",
      "scope": [
        "entity.name.tag.decorator",
        "meta.decorator",
        "punctuation.decorator"
      ],
      "settings": { "foreground": "#506090", "fontStyle": "italic" }
    },
    {
      "name": "Import / Module",
      "scope": ["entity.name.module", "string.quoted.import"],
      "settings": { "foreground": "#7888A0" }
    },
    {
      "name": "HTML tag",
      "scope": ["entity.name.tag", "meta.tag.sgml"],
      "settings": { "foreground": "#6070A0" }
    },
    {
      "name": "HTML attribute",
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#4A8888" }
    },
    {
      "name": "CSS property",
      "scope": ["support.type.property-name.css"],
      "settings": { "foreground": "#4A8888" }
    },
    {
      "name": "CSS value",
      "scope": ["support.constant.property-value.css"],
      "settings": { "foreground": "#7888A0" }
    },
    {
      "name": "CSS selector",
      "scope": [
        "entity.name.tag.css",
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css"
      ],
      "settings": { "foreground": "#5888A8" }
    },
    {
      "name": "Markdown heading",
      "scope": [
        "markup.heading",
        "entity.name.section.markdown",
        "punctuation.definition.heading.markdown"
      ],
      "settings": { "foreground": "#6070A0", "fontStyle": "bold" }
    },
    {
      "name": "Markdown bold",
      "scope": ["markup.bold"],
      "settings": { "foreground": "#D8E0EC", "fontStyle": "bold" }
    },
    {
      "name": "Markdown italic",
      "scope": ["markup.italic"],
      "settings": { "foreground": "#A8B4C4", "fontStyle": "italic" }
    },
    {
      "name": "Markdown link title",
      "scope": [
        "string.other.link.title.markdown",
        "meta.link.inline.markdown"
      ],
      "settings": { "foreground": "#B0BCC8" }
    },
    {
      "name": "Markdown link URL",
      "scope": [
        "markup.underline.link",
        "meta.link.reference.markdown",
        "string.other.link.description.markdown",
        "punctuation.definition.link.markdown",
        "markup.underline.link.markdown"
      ],
      "settings": { "foreground": "#4A5870" }
    },
    {
      "name": "Markdown list marker",
      "scope": [
        "punctuation.definition.list.begin.markdown",
        "beginning.punctuation.definition.list.markdown"
      ],
      "settings": { "foreground": "#6070A0" }
    },
    {
      "name": "Markdown code",
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code.block",
        "fenced_code.block.language"
      ],
      "settings": { "foreground": "#5ABABA" }
    },
    {
      "name": "JSON key",
      "scope": ["support.type.property-name.json"],
      "settings": { "foreground": "#4A8888" }
    },
    {
      "name": "Invalid / Deprecated",
      "scope": ["invalid", "invalid.deprecated"],
      "settings": { "foreground": "#6878A8", "fontStyle": "underline" }
    }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "variable": "#C8D0DC",
    "variable.readonly": "#7888A0",
    "parameter": "#A8B4C4",
    "property": "#B0BCC8",
    "function": "#4A8888",
    "method": "#4A8888",
    "class": "#5888A8",
    "interface": "#5888A8",
    "type": "#5888A8",
    "enum": "#5888A8",
    "enumMember": "#7888A0",
    "keyword": "#6070A0",
    "string": "#7888A0",
    "number": "#5ABABA",
    "comment": { "foreground": "#283850", "italic": true },
    "decorator": { "foreground": "#506090", "italic": true },
    "namespace": "#5888A8"
  }
}
