  "tokenColors": [
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#3E3565", "fontStyle": "italic" }
    },
    {
      "name": "String",
      "scope": ["string", "string.quoted", "string.template"],
      "settings": { "foreground": "#A8CCE0" }
    },
    {
      "name": "String escape",
      "scope": ["constant.character.escape", "string.regexp"],
      "settings": { "foreground": "#C0E0F0" }
    },
    {
      "name": "Number",
      "scope": ["constant.numeric"],
      "settings": { "foreground": "#7AB8D8" }
    },
    {
      "name": "Boolean / Null",
      "scope": [
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined"
      ],
      "settings": { "foreground": "#7AB8D8" }
    },
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": { "foreground": "#5A90C8" }
    },
    {
      "name": "Function / Method",
      "scope": [
        "entity.name.function",
        "meta.function-call",
        "support.function",
        "variable.function"
      ],
      "settings": { "foreground": "#2ABCCC" }
    },
    {
      "name": "Class / Type",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.class",
        "support.type"
      ],
      "settings": { "foreground": "#38C8D8" }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite"
      ],
      "settings": { "foreground": "#E8F0F8" }
    },
    {
      "name": "Variable — parameter",
      "scope": ["variable.parameter"],
      "settings": { "foreground": "#C8DCE8" }
    },
    {
      "name": "Constant",
      "scope": ["variable.other.constant", "constant.other"],
      "settings": { "foreground": "#A8CCE0", "fontStyle": "bold" }
    },
    {
      "name": "Property",
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key"
      ],
      "settings": { "foreground": "#C0D8E8" }
    },
    {
      "name": "Operator",
      "scope": ["keyword.operator", "punctuation.separator", "punctuation.accessor"],
      "settings": { "foreground": "#7A9CB8" }
    },
    {
      "name": "Punctuation",
      "scope": ["punctuation", "meta.brace", "meta.delimiter"],
      "settings": { "foreground": "#4A6880" }
    },
    {
      "name": "Decorator / Annotation",
      "scope": [
        "entity.name.tag.decorator",
        "meta.decorator",
        "punctuation.decorator"
      ],
      "settings": { "foreground": "#7868C0", "fontStyle": "italic" }
    },
    {
      "name": "Import / Module",
      "scope": ["entity.name.module", "string.quoted.import"],
      "settings": { "foreground": "#A8CCE0" }
    },
    {
      "name": "HTML tag",
      "scope": ["entity.name.tag", "meta.tag.sgml"],
      "settings": { "foreground": "#5A90C8" }
    },
    {
      "name": "HTML attribute",
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#2ABCCC" }
    },
    {
      "name": "CSS property",
      "scope": ["support.type.property-name.css"],
      "settings": { "foreground": "#2ABCCC" }
    },
    {
      "name": "CSS value",
      "scope": ["support.constant.property-value.css"],
      "settings": { "foreground": "#A8CCE0" }
    },
    {
      "name": "CSS selector",
      "scope": [
        "entity.name.tag.css",
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css"
      ],
      "settings": { "foreground": "#38C8D8" }
    },
    {
      "name": "Markdown heading",
      "scope": [
        "markup.heading",
        "entity.name.section.markdown",
        "punctuation.definition.heading.markdown"
      ],
      "settings": { "foreground": "#5A90C8", "fontStyle": "bold" }
    },
    {
      "name": "Markdown bold",
      "scope": ["markup.bold"],
      "settings": { "foreground": "#E8F0F8", "fontStyle": "bold" }
    },
    {
      "name": "Markdown italic",
      "scope": ["markup.italic"],
      "settings": { "foreground": "#C8DCE8", "fontStyle": "italic" }
    },
    {
      "name": "Markdown link title",
      "scope": [
        "string.other.link.title.markdown",
        "meta.link.inline.markdown"
      ],
      "settings": { "foreground": "#C0D8E8" }
    },
    {
      "name": "Markdown link URL",
      "scope": [
        "markup.underline.link",
        "meta.link.reference.markdown",
        "string.other.link.description.markdown",
        "punctuation.definition.link.markdown",
        "markup.underline.link.markdown"
      ],
      "settings": { "foreground": "#8AACC0" }
    },
    {
      "name": "Markdown list marker",
      "scope": [
        "punctuation.definition.list.begin.markdown",
        "beginning.punctuation.definition.list.markdown"
      ],
      "settings": { "foreground": "#5A90C8" }
    },
    {
      "name": "Markdown code",
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code.block",
        "fenced_code.block.language"
      ],
      "settings": { "foreground": "#38C8D8" }
    },
    {
      "name": "JSON key",
      "scope": ["support.type.property-name.json"],
      "settings": { "foreground": "#2ABCCC" }
    },
    {
      "name": "Invalid / Deprecated",
      "scope": ["invalid", "invalid.deprecated"],
      "settings": { "foreground": "#C05070", "fontStyle": "underline" }
    }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "variable": "#E8F0F8",
    "variable.readonly": "#A8CCE0",
    "parameter": "#C8DCE8",
    "property": "#C0D8E8",
    "function": "#2ABCCC",
    "method": "#2ABCCC",
    "class": "#38C8D8",
    "interface": "#38C8D8",
    "type": "#38C8D8",
    "enum": "#38C8D8",
    "enumMember": "#A8CCE0",
    "keyword": "#5A90C8",
    "string": "#A8CCE0",
    "number": "#7AB8D8",
    "comment": { "foreground": "#3E3565", "italic": true },
    "decorator": { "foreground": "#7868C0", "italic": true },
    "namespace": "#38C8D8"
  }
}
