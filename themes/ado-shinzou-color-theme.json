  "tokenColors": [
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#5A2828", "fontStyle": "italic" }
    },
    {
      "name": "String",
      "scope": ["string", "string.quoted", "string.template"],
      "settings": { "foreground": "#A09278" }
    },
    {
      "name": "String escape",
      "scope": ["constant.character.escape", "string.regexp"],
      "settings": { "foreground": "#C0A888" }
    },
    {
      "name": "Number",
      "scope": ["constant.numeric"],
      "settings": { "foreground": "#35D0D8" }
    },
    {
      "name": "Boolean / Null",
      "scope": [
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined"
      ],
      "settings": { "foreground": "#35D0D8" }
    },
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": { "foreground": "#C42040" }
    },
    {
      "name": "Function / Method",
      "scope": [
        "entity.name.function",
        "meta.function-call",
        "support.function",
        "variable.function"
      ],
      "settings": { "foreground": "#20C0CC" }
    },
    {
      "name": "Class / Type",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.class",
        "support.type"
      ],
      "settings": { "foreground": "#35D0D8" }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite"
      ],
      "settings": { "foreground": "#C8D4DC" }
    },
    {
      "name": "Variable — parameter",
      "scope": ["variable.parameter"],
      "settings": { "foreground": "#B0BCC8" }
    },
    {
      "name": "Constant",
      "scope": ["variable.other.constant", "constant.other"],
      "settings": { "foreground": "#A09278", "fontStyle": "bold" }
    },
    {
      "name": "Property",
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key"
      ],
      "settings": { "foreground": "#B8C8D4" }
    },
    {
      "name": "Operator",
      "scope": ["keyword.operator", "punctuation.separator", "punctuation.accessor"],
      "settings": { "foreground": "#6A8090" }
    },
    {
      "name": "Punctuation",
      "scope": ["punctuation", "meta.brace", "meta.delimiter"],
      "settings": { "foreground": "#4A5A68" }
    },
    {
      "name": "Decorator / Annotation",
      "scope": [
        "entity.name.tag.decorator",
        "meta.decorator",
        "punctuation.decorator"
      ],
      "settings": { "foreground": "#803060", "fontStyle": "italic" }
    },
    {
      "name": "Import / Module",
      "scope": ["entity.name.module", "string.quoted.import"],
      "settings": { "foreground": "#A09278" }
    },
    {
      "name": "HTML tag",
      "scope": ["entity.name.tag", "meta.tag.sgml"],
      "settings": { "foreground": "#C42040" }
    },
    {
      "name": "HTML attribute",
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#20C0CC" }
    },
    {
      "name": "CSS property",
      "scope": ["support.type.property-name.css"],
      "settings": { "foreground": "#20C0CC" }
    },
    {
      "name": "CSS value",
      "scope": ["support.constant.property-value.css"],
      "settings": { "foreground": "#A09278" }
    },
    {
      "name": "CSS selector",
      "scope": [
        "entity.name.tag.css",
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css"
      ],
      "settings": { "foreground": "#35D0D8" }
    },
    {
      "name": "Markdown heading",
      "scope": [
        "markup.heading",
        "entity.name.section.markdown",
        "punctuation.definition.heading.markdown"
      ],
      "settings": { "foreground": "#C42040", "fontStyle": "bold" }
    },
    {
      "name": "Markdown bold",
      "scope": ["markup.bold"],
      "settings": { "foreground": "#E0E8F0", "fontStyle": "bold" }
    },
    {
      "name": "Markdown italic",
      "scope": ["markup.italic"],
      "settings": { "foreground": "#B0BCC8", "fontStyle": "italic" }
    },
    {
      "name": "Markdown link title",
      "scope": [
        "string.other.link.title.markdown",
        "meta.link.inline.markdown"
      ],
      "settings": { "foreground": "#B8C8D4" }
    },
    {
      "name": "Markdown link URL",
      "scope": [
        "markup.underline.link",
        "meta.link.reference.markdown",
        "string.other.link.description.markdown",
        "punctuation.definition.link.markdown",
        "markup.underline.link.markdown"
      ],
      "settings": { "foreground": "#6A8090" }
    },
    {
      "name": "Markdown list marker",
      "scope": [
        "punctuation.definition.list.begin.markdown",
        "beginning.punctuation.definition.list.markdown"
      ],
      "settings": { "foreground": "#C42040" }
    },
    {
      "name": "Markdown code",
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code.block",
        "fenced_code.block.language"
      ],
      "settings": { "foreground": "#35D0D8" }
    },
    {
      "name": "JSON key",
      "scope": ["support.type.property-name.json"],
      "settings": { "foreground": "#20C0CC" }
    },
    {
      "name": "Invalid / Deprecated",
      "scope": ["invalid", "invalid.deprecated"],
      "settings": { "foreground": "#E03050", "fontStyle": "underline" }
    }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "variable": "#C8D4DC",
    "variable.readonly": "#A09278",
    "parameter": "#B0BCC8",
    "property": "#B8C8D4",
    "function": "#20C0CC",
    "method": "#20C0CC",
    "class": "#35D0D8",
    "interface": "#35D0D8",
    "type": "#35D0D8",
    "enum": "#35D0D8",
    "enumMember": "#A09278",
    "keyword": "#C42040",
    "string": "#A09278",
    "number": "#35D0D8",
    "comment": { "foreground": "#5A2828", "italic": true },
    "decorator": { "foreground": "#803060", "italic": true },
    "namespace": "#35D0D8"
  }
}
