  "tokenColors": [
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#1E3850", "fontStyle": "italic" }
    },
    {
      "name": "String",
      "scope": ["string", "string.quoted", "string.template"],
      "settings": { "foreground": "#5090B8" }
    },
    {
      "name": "String escape",
      "scope": ["constant.character.escape", "string.regexp"],
      "settings": { "foreground": "#70B0D0" }
    },
    {
      "name": "Number",
      "scope": ["constant.numeric"],
      "settings": { "foreground": "#80F0FF" }
    },
    {
      "name": "Boolean / Null",
      "scope": [
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined"
      ],
      "settings": { "foreground": "#80F0FF" }
    },
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": { "foreground": "#00C8E0" }
    },
    {
      "name": "Function / Method",
      "scope": [
        "entity.name.function",
        "meta.function-call",
        "support.function",
        "variable.function"
      ],
      "settings": { "foreground": "#40E8F8" }
    },
    {
      "name": "Class / Type",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.class",
        "support.type"
      ],
      "settings": { "foreground": "#60F0FC" }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite"
      ],
      "settings": { "foreground": "#C8E4F0" }
    },
    {
      "name": "Variable — parameter",
      "scope": ["variable.parameter"],
      "settings": { "foreground": "#A8CCE0" }
    },
    {
      "name": "Constant",
      "scope": ["variable.other.constant", "constant.other"],
      "settings": { "foreground": "#5090B8", "fontStyle": "bold" }
    },
    {
      "name": "Property",
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key"
      ],
      "settings": { "foreground": "#B0D8EC" }
    },
    {
      "name": "Operator",
      "scope": ["keyword.operator", "punctuation.separator", "punctuation.accessor"],
      "settings": { "foreground": "#3A7090" }
    },
    {
      "name": "Punctuation",
      "scope": ["punctuation", "meta.brace", "meta.delimiter"],
      "settings": { "foreground": "#284858" }
    },
    {
      "name": "Decorator / Annotation",
      "scope": [
        "entity.name.tag.decorator",
        "meta.decorator",
        "punctuation.decorator"
      ],
      "settings": { "foreground": "#1050A0", "fontStyle": "italic" }
    },
    {
      "name": "Import / Module",
      "scope": ["entity.name.module", "string.quoted.import"],
      "settings": { "foreground": "#5090B8" }
    },
    {
      "name": "HTML tag",
      "scope": ["entity.name.tag", "meta.tag.sgml"],
      "settings": { "foreground": "#00C8E0" }
    },
    {
      "name": "HTML attribute",
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#40E8F8" }
    },
    {
      "name": "CSS property",
      "scope": ["support.type.property-name.css"],
      "settings": { "foreground": "#40E8F8" }
    },
    {
      "name": "CSS value",
      "scope": ["support.constant.property-value.css"],
      "settings": { "foreground": "#5090B8" }
    },
    {
      "name": "CSS selector",
      "scope": [
        "entity.name.tag.css",
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css"
      ],
      "settings": { "foreground": "#60F0FC" }
    },
    {
      "name": "Markdown heading",
      "scope": [
        "markup.heading",
        "entity.name.section.markdown",
        "punctuation.definition.heading.markdown"
      ],
      "settings": { "foreground": "#00C8E0", "fontStyle": "bold" }
    },
    {
      "name": "Markdown bold",
      "scope": ["markup.bold"],
      "settings": { "foreground": "#E0F4FC", "fontStyle": "bold" }
    },
    {
      "name": "Markdown italic",
      "scope": ["markup.italic"],
      "settings": { "foreground": "#A8CCE0", "fontStyle": "italic" }
    },
    {
      "name": "Markdown link title",
      "scope": [
        "string.other.link.title.markdown",
        "meta.link.inline.markdown"
      ],
      "settings": { "foreground": "#B0D8EC" }
    },
    {
      "name": "Markdown link URL",
      "scope": [
        "markup.underline.link",
        "meta.link.reference.markdown",
        "string.other.link.description.markdown",
        "punctuation.definition.link.markdown",
        "markup.underline.link.markdown"
      ],
      "settings": { "foreground": "#3A7090" }
    },
    {
      "name": "Markdown list marker",
      "scope": [
        "punctuation.definition.list.begin.markdown",
        "beginning.punctuation.definition.list.markdown"
      ],
      "settings": { "foreground": "#00C8E0" }
    },
    {
      "name": "Markdown code",
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code.block",
        "fenced_code.block.language"
      ],
      "settings": { "foreground": "#60F0FC" }
    },
    {
      "name": "JSON key",
      "scope": ["support.type.property-name.json"],
      "settings": { "foreground": "#40E8F8" }
    },
    {
      "name": "Invalid / Deprecated",
      "scope": ["invalid", "invalid.deprecated"],
      "settings": { "foreground": "#3080E0", "fontStyle": "underline" }
    }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "variable": "#C8E4F0",
    "variable.readonly": "#5090B8",
    "parameter": "#A8CCE0",
    "property": "#B0D8EC",
    "function": "#40E8F8",
    "method": "#40E8F8",
    "class": "#60F0FC",
    "interface": "#60F0FC",
    "type": "#60F0FC",
    "enum": "#60F0FC",
    "enumMember": "#5090B8",
    "keyword": "#00C8E0",
    "string": "#5090B8",
    "number": "#80F0FF",
    "comment": { "foreground": "#1E3850", "italic": true },
    "decorator": { "foreground": "#1050A0", "italic": true },
    "namespace": "#60F0FC"
  }
}
