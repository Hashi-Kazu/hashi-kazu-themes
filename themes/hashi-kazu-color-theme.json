  "tokenColors": [
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#3E3055", "fontStyle": "italic" }
    },
    {
      "name": "String",
      "scope": ["string", "string.quoted", "string.template"],
      "settings": { "foreground": "#C8B080" }
    },
    {
      "name": "String escape",
      "scope": ["constant.character.escape", "string.regexp"],
      "settings": { "foreground": "#E8C880" }
    },
    {
      "name": "Number",
      "scope": ["constant.numeric"],
      "settings": { "foreground": "#D4A84B" }
    },
    {
      "name": "Boolean / Null",
      "scope": [
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined"
      ],
      "settings": { "foreground": "#D4A84B" }
    },
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": { "foreground": "#9B7FD4" }
    },
    {
      "name": "Function / Method",
      "scope": [
        "entity.name.function",
        "meta.function-call",
        "support.function",
        "variable.function"
      ],
      "settings": { "foreground": "#E8C068" }
    },
    {
      "name": "Class / Type",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.class",
        "support.type"
      ],
      "settings": { "foreground": "#B89FE8" }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite"
      ],
      "settings": { "foreground": "#F0E8D8" }
    },
    {
      "name": "Variable — parameter",
      "scope": ["variable.parameter"],
      "settings": { "foreground": "#E0D0B8" }
    },
    {
      "name": "Constant",
      "scope": ["variable.other.constant", "constant.other"],
      "settings": { "foreground": "#C8B080", "fontStyle": "bold" }
    },
    {
      "name": "Property",
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key"
      ],
      "settings": { "foreground": "#D8C898" }
    },
    {
      "name": "Operator",
      "scope": ["keyword.operator", "punctuation.separator", "punctuation.accessor"],
      "settings": { "foreground": "#A08858" }
    },
    {
      "name": "Punctuation",
      "scope": ["punctuation", "meta.brace", "meta.delimiter"],
      "settings": { "foreground": "#604840" }
    },
    {
      "name": "Decorator / Annotation",
      "scope": [
        "entity.name.tag.decorator",
        "meta.decorator",
        "punctuation.decorator"
      ],
      "settings": { "foreground": "#9B7FD4", "fontStyle": "italic" }
    },
    {
      "name": "Import / Module",
      "scope": ["entity.name.module", "string.quoted.import"],
      "settings": { "foreground": "#C8B080" }
    },
    {
      "name": "HTML tag",
      "scope": ["entity.name.tag", "meta.tag.sgml"],
      "settings": { "foreground": "#9B7FD4" }
    },
    {
      "name": "HTML attribute",
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#E8C068" }
    },
    {
      "name": "CSS property",
      "scope": ["support.type.property-name.css"],
      "settings": { "foreground": "#E8C068" }
    },
    {
      "name": "CSS value",
      "scope": ["support.constant.property-value.css"],
      "settings": { "foreground": "#C8B080" }
    },
    {
      "name": "CSS selector",
      "scope": [
        "entity.name.tag.css",
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css"
      ],
      "settings": { "foreground": "#B89FE8" }
    },
    {
      "name": "Markdown heading",
      "scope": [
        "markup.heading",
        "entity.name.section.markdown",
        "punctuation.definition.heading.markdown"
      ],
      "settings": { "foreground": "#D4A84B", "fontStyle": "bold" }
    },
    {
      "name": "Markdown bold",
      "scope": ["markup.bold"],
      "settings": { "foreground": "#F0E8D8", "fontStyle": "bold" }
    },
    {
      "name": "Markdown italic",
      "scope": ["markup.italic"],
      "settings": { "foreground": "#E0D0B8", "fontStyle": "italic" }
    },
    {
      "name": "Markdown link title",
      "scope": [
        "string.other.link.title.markdown",
        "meta.link.inline.markdown"
      ],
      "settings": { "foreground": "#D8C898" }
    },
    {
      "name": "Markdown link URL",
      "scope": [
        "markup.underline.link",
        "meta.link.reference.markdown",
        "string.other.link.description.markdown",
        "punctuation.definition.link.markdown",
        "markup.underline.link.markdown"
      ],
      "settings": { "foreground": "#C0A878" }
    },
    {
      "name": "Markdown list marker",
      "scope": [
        "punctuation.definition.list.begin.markdown",
        "beginning.punctuation.definition.list.markdown"
      ],
      "settings": { "foreground": "#D4A84B" }
    },
    {
      "name": "Markdown code",
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code.block",
        "fenced_code.block.language"
      ],
      "settings": { "foreground": "#E8C068" }
    },
    {
      "name": "JSON key",
      "scope": ["support.type.property-name.json"],
      "settings": { "foreground": "#E8C068" }
    },
    {
      "name": "Invalid / Deprecated",
      "scope": ["invalid", "invalid.deprecated"],
      "settings": { "foreground": "#C85050", "fontStyle": "underline" }
    }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "variable": "#F0E8D8",
    "variable.readonly": "#C8B080",
    "parameter": "#E0D0B8",
    "property": "#D8C898",
    "function": "#E8C068",
    "method": "#E8C068",
    "class": "#B89FE8",
    "interface": "#B89FE8",
    "type": "#B89FE8",
    "enum": "#B89FE8",
    "enumMember": "#C8B080",
    "keyword": "#9B7FD4",
    "string": "#C8B080",
    "number": "#D4A84B",
    "comment": { "foreground": "#3E3055", "italic": true },
    "decorator": { "foreground": "#9B7FD4", "italic": true },
    "namespace": "#B89FE8"
  }
}
